// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url is now handled by prisma.config.ts
}

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  email         String    @unique
  image         String?
  bio           String?   @db.Text
  links         Link[]
  createdAt     DateTime  @default(now())
}

model Link {
  id        String   @id @default(cuid())
  title     String
  url       String
  order     Int      @default(0)
  archived  Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}